tom:24},children:[u.jsx("div",{style:{color:f.accent,fontWeight:800,fontSize:14,marginBottom:8},children:"💵 核心問題：平台如何把資料工作負載轉成持續收入？"}),u.jsx("div",{style:{color:f.text,fontSize:13,lineHeight:1.8},children:"Databricks 與 Snowflake 都不是靠一次性軟體授權獲利，而是以「使用量」驅動營收。客戶資料越多、查詢越頻繁、工作負載越廣，平台收入就越高。 因此應觀察的不是 AI 功能數量，而是用量成長、客戶擴張、毛利率、現金流、銷售效率，以及高額股票薪酬是否逐步下降。"})]}),u.jsx(jg,{}),u.jsx(Ag,{}),u.jsx(En,{no:"1",title:"收入引擎：用量越大，平台賺得越多",db:"主要以 DBU 計算用量收費。資料工程、SQL、串流、模型訓練與服務等工作負載都可轉化為消費收入；平台涵蓋的工作流程越多，單一客戶貢獻越高。",sf:"主要以 Credit 計算資源消耗，另收儲存費。查詢、資料處理、共享與應用工作負載會持續消耗 Credit；容量承諾合約可提高收入可預測性。",tw:"兩者本質都是 consumption business。獲利關鍵不是簽下多少帳戶，而是客戶上線後是否持續增加資料量、查詢量與工作負載。"}),u.jsx(En,{no:"2",title:"客戶擴張：先進一個部門，再吃下整個企業",db:"常由工程或資料科學團隊切入，再擴張至 BI、治理、即時資料與企業 AI。開源工具形成開發者入口，企業版功能與治理能力負責將免費採用轉成高額商業合約。",sf:"通常從資料倉儲與分析切入，再擴展至資料共享、應用開發、治理及 AI。企業一旦把資料與跨部門流程建立在平台上，轉換成本會提高，續約與增購機率也隨之上升。",tw:"NRR、百萬美元級客戶數及大型客戶消費成長，比單純客戶總數更能反映未來營收與定價權。"}),u.jsx(En,{no:"3",title:"毛利與現金流：規模效應決定真正賺錢能力",db:"媒體報導毛利率已由 2024 年 80%+降至約 74%；CEO 表示 AI Agent 大量查詢推高基礎設施成本，預期毛利率仍可能下降。約 74%屬外部估算，並非公司審計財報。",sf:"產品毛利率高且自由現金流為正，顯示營運可產生現金；但 GAAP 仍虧損，主要受到股票薪酬、研發及銷售費用影響。Non-GAAP 獲利不能完全取代 GAAP 判讀。",tw:"判斷是否真正獲利，要同時看 GAAP 淨利、營業利益、自由現金流與股票薪酬占營收比，不能只看調整後利潤。"}),u.jsx(En,{no:"4",title:"成本槓桿：研發與銷售投入能否轉成更高收入",db:"持續投入工程人才、產品研發、收購與全球銷售，以快速擴大平台邊界。若收入增速長期高於人員與雲端成本增速，營業槓桿才會逐步出現。",sf:"已建立大型直銷與合作夥伴體系，但銷售、研發及股票薪酬仍高。未來獲利改善取決於銷售效率提升、既有客戶增購，以及費用增速低於產品收入增速。",tw:"成長公司不是費用越低越好；重點是每投入一元研發或銷售費，能否帶來更多可續約、可擴張的高毛利收入。"}),u.jsx(En,{no:"5",title:"最終獲利判斷：成長品質比成長速度更重要",db:"優勢是高速成長、開源入口與跨工作負載擴張能力；風險是私人公司資訊透明度有限、估值高，以及大規模研發與收購能否有效轉化為長期利潤。",sf:"優勢是成熟的企業客戶基礎、高產品毛利與正自由現金流；風險是 GAAP 虧損、高股票薪酬、雲端平台競爭，以及客戶成本優化造成用量波動。",tw:"🏆 核心結論：Databricks 更像以高速擴張換取未來規模獲利；Snowflake 已證明現金創造能力，但仍需把調整後獲利轉成 GAAP 淨利。持續追蹤用量成長、NRR、大客戶、毛利率、自由現金流與股票薪酬。"})]});case 10:return u.jsxs(kt,{title:"",children:[u.jsxs("div",{style:{display:"flex",alignItems:"center",gap:12,margin:"-6px 0 16px",padding:"10px 14px",background:"#fff",border:`1px solid ${f.databricks}33`,borderRadius:10},children:[u.jsx("div",{className:"brand-locku